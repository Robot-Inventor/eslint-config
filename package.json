{
  "name": "@robot-inventor/eslint-config",
  "version": "13.0.1",
  "description": "My ESLint config preset",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint --flag unstable_native_nodejs_ts_config \"./src/**/*.ts\"",
    "format": "prettier --write ./**/*.ts",
    "format:check": "prettier --check ./**/*.ts",
    "ci:version": "changeset version",
    "ci:publish": "npm run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Robot-Inventor/eslint-config.git"
  },
  "keywords": [
    "eslint"
  ],
  "author": "Robot-Inventor",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Robot-Inventor/eslint-config/issues"
  },
  "homepage": "https://github.com/Robot-Inventor/eslint-config#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.17.3",
    "@eslint-react/kit": "^5.17.3",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.11",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/types": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "eslint-plugin-react-doctor": "^0.8.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.64.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@eslint-types/jsdoc": "^48.2.2",
    "@eslint-types/typescript-eslint": "^7.5.0",
    "@robot-inventor/tsconfig-base": "^7.1.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@typescript-eslint/types": "^8.64.0",
    "zod-validation-error": "^5.0.0"
  }
}
